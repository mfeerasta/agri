{
  "name": "@zameen/mobile-ops",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor native shell wrapping the Zameen ops PWA for tablets (iPad + Galaxy Tab).",
  "scripts": {
    "sync": "cap sync",
    "ios": "cap open ios",
    "android": "cap open android",
    "build:bridge": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "android:assemble": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.1",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/local-notifications": "^6.1.0",
    "@capacitor/network": "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.2",
    "@capacitor/share": "^6.0.2",
    "@sentry/capacitor": "^1.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/android": "^6.1.2",
    "typescript": "^5.6.3"
  }
}

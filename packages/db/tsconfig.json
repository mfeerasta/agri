{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__mocks__/**",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/seed.ts",
    "src/seed-minimal.ts"
  ]
}
